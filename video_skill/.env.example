# === Video Creator Skill — конфигурация ===
# Копируй в .env и заполняй по мере необходимости

# === Профиль по умолчанию (Phase 1) ===
# Используется если не передан --profile=<name>
# Доступные: lab, wl, coach, experts, market
PROFILE_DEFAULT=lab

# === Пути (обязательные) ===
# Корень этого скила (auto-detect если не задан)
# VIDEO_SKILL_ROOT=C:/Users/kfigh/video_skill

# WishLibrarian (для LLM-фабрики)
# WL_ROOT=C:/Users/kfigh/wish_librarian

# Publisher (для Phase 4 — публикация)
# PUBLISHER_SKILL_ROOT=C:/Users/kfigh/publisher_skill

# Lab site (для Phase 4 — Astro-страница)
# LAB_SITE_ROOT=C:/Users/kfigh/lab_site

# === Phase 1: LLM ===
# Используется wish_librarian/agent/ai/factory.py (singleton)
# Провайдеры: claude (default) / yandex / gigachat / fallback
# Ключи читаются из .env wish_librarian (CLAUDE_API_KEY / YANDEX_API_KEY / GIGACHAT_*)

# === Phase 2: Auto-режим (стоки + TTS + BGM) ===
# PEXELS_API_KEY=...                       # https://www.pexels.com/api/
# PIXABAY_API_KEY=...                      # https://pixabay.com/service/about/api/
# YANDEX_SPEECHKIT_API_KEY=...              # переиспользовать от audio_skill
# YC_FOLDER_ID=...                         # Yandex Cloud folder
# FFMPEG_BIN=C:/tools/ffmpeg/bin/ffmpeg.exe # путь к ffmpeg 7.x/8.x

# === Phase 3: Manual-режим (нарезка видео) ===
# yt-dlp ставится через pip (не env)

# === Phase 4: Публикация (4 канала + R2) ===
# CF_ACCOUNT_ID=...
# CF_API_TOKEN=...                         # wrangler
# CF_R2_BUCKET=pulab-video
# TG_BOT_TOKEN=...                         # от @BotFather
# TG_CHANNEL_ID=@pulaab_ru
# VK_ACCESS_TOKEN=...
# VK_GROUP_ID=237295798
# OK_ACCESS_TOKEN=...
# OK_GROUP_ID=...
# OK_APPLICATION_KEY=...
# OK_APPLICATION_SECRET=...

# === Logging ===
LOG_LEVEL=INFO
# Логи в logs/video-YYYYMMDD.log
