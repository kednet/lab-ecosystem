# image_skill .env example
# Ключи берутся из wish_librarian/.env (одинаковые).
# Скопируй wish_librarian/.env в image_skill/.env если нужно локально.

# Profile по умолчанию (lab | wl | coach | experts | market)
PROFILE_DEFAULT=lab

# YandexART API (тот же ключ что для YandexGPT)
YANDEX_API_KEY=AQVNxxxx_xxxx
YANDEX_FOLDER_ID=b1xxxxxx
YANDEX_MODEL_ART=art://b1xxxxxx/yandex-art/latest

# Phase 2/3 (заглушки)
# FFMPEG_BIN=C:/tools/ffmpeg/bin/ffmpeg.exe  # Phase 2: upscale pipeline
# R2_* ключи                                  # Phase 3: интеграция с publisher_skill
