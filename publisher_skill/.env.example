# Publisher Skill — пример .env
# Скопируй в .env и заполни реальными значениями

# === lab_site (целевой сайт) ===
LAB_SITE_ROOT=C:/Users/kfigh/lab_site
WL_OUTPUT_ROOT=C:/Users/kfigh/wish_librarian/output/library

# === Cloudflare Pages (деплой) ===
CF_ACCOUNT_ID=80ba4de511365824283fec3678626c75
CF_API_TOKEN=                     # wrangler обычно берёт из `wrangler login`, но для CI — задать
CF_PAGES_PROJECT=pulab

# === Telegram Bot (анонс + admin notify) ===
TG_BOT_TOKEN=                     # от @BotFather
TG_CHANNEL_ID=@pulaab_ru          # канал для анонсов
TG_ADMIN_CHAT_ID=                 # личка @kfigh (числовой id или @username)

# === VK API (анонс) ===
VK_ACCESS_TOKEN=                  # токен сообщества pulabru (id=237295798)
VK_GROUP_ID=237295798

# === Одноклассники (анонс) ===
# Получить: https://apiok.ru/wiki/display/api/Authorization
# 1. Создать приложение в OK Dev (https://apiok.ru/dev)
# 2. Тип: GROUP_INSTALL
# 3. Права: VALUABLE_ACCESS, GROUP_CONTENT, PHOTO_CONTENT
# 4. Пройти OAuth с правами GROUP_CONTENT
OK_ACCESS_TOKEN=
OK_GROUP_ID=                     # id группы OK (цифрами, не слаг)
OK_APPLICATION_KEY=              # публичный ключ приложения
OK_APPLICATION_SECRET=           # секрет приложения

# === Яндекс.Дзен ===
# Дзен сам подтягивает RSS — токен не нужен.
# В Дзен Studio → «Каналы» → «Добавить канал» → «Внешний RSS»
# Указать: https://app.pulab.ru/detector/feed.xml (или аналог)
ZEN_RSS_URL=                     # опционально, для верификации

# === SMTP (Phase 2+, email-рассылка) ===
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_USER=noreply@pulab.online
# SMTP_PASSWORD=
# EMAIL_FROM="Лаборатория желаний <noreply@pulab.online>"
# EMAIL_LIST=lab_subscribers.txt
