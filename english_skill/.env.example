# === English Trainer Skill — конфигурация ===
# Phase 1 (MVP) — НЕ требует никаких ключей. Все скрипты работают офлайн.
# Скопируй в .env и заполняй по мере необходимости.

# === Пути (опционально, auto-detect работает) ===
# Корень этого скила (auto-detect если не задан)
# ENGLISH_SKILL_ROOT=C:/Users/kfigh/english_skill

# === Phase 2 (НЕ используются в v1.0) ===
# LLM-фидбек на ответы пользователя
# YANDEX_GPT_API_KEY=
# (или ANTHROPIC_API_KEY= — фабрика WL поддерживает оба)

# TTS-озвучка эталонов диалогов
# YANDEX_SPEECHKIT_API_KEY=
# FOLDER_ID=   # Yandex Cloud folder id

# Speech recognition (Phase 3)
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=

# === Прочее (Phase 1) ===
# Текущий уровень (для будущей адаптации, сейчас не используется)
# USER_LEVEL=B1

# Тема глоссария по умолчанию (если не передан --topic)
# GLOSSARY_DEFAULT_TOPIC=meetings
