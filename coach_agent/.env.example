# === WishCoach — env (Phase 0) ===
# Скопируй в .env и заполни секреты

# --- Общее ---
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
COACH_TIMEZONE=Europe/Moscow

# --- Cloudflare D1 (общая БД с lab_site) ---
# Account ID дашборда Cloudflare
CF_ACCOUNT_ID=your_account_id_here
# Database ID из D1 → wishlab-coach-db
CF_D1_DATABASE_ID=your_d1_database_id_here
# API Token с правами "D1: Edit"
CF_API_TOKEN=your_cf_api_token_here

# --- AI (Phase 1+) ---
ANTHROPIC_API_KEY=
YANDEXGPT_API_KEY=
YANDEXGPT_FOLDER_ID=

# --- Telegram (Phase 6+) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=wishlab_coach_bot

# --- VK (Phase 7+) ---
VK_GROUP_TOKEN=
VK_GROUP_ID=237295798
VK_CONFIRMATION_CODE=
VK_CALLBACK_SECRET=

# --- Render (Phase 0: деплой) ---
# Авто-выставляется Render; оставь пустым локально
RENDER_EXTERNAL_URL=
RENDER_SERVICE_NAME=wishcoach

# --- Корпоративный MITM (см. memory: corporate-mitm-proxy) ---
# На рабочей машине ОБЯЗАТЕЛЬНО false, иначе TLS-MITM уронит запросы
VERIFY_SSL=false
# SOCKS5-прокси (опционально, если не через системный)
SOCKS5_PROXY=socks5h://127.0.0.1:10808

# --- Админ-уведомления (опционально) ---
ADMIN_TELEGRAM_ID=
