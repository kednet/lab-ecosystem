# ╔══════════════════════════════════════════════════════════════════╗
# ║  WishLibrarian — конфигурация AI-провайдеров и не только          ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Скопируйте этот файл в .env и заполните ключи выбранного провайдера.
# AI_PROVIDER определяет, какой клиент будет использоваться.

# ───────────────────────────────────────────────────────────────────
# AI-провайдер (claude | yandex | gigachat | fallback)
# ───────────────────────────────────────────────────────────────────
AI_PROVIDER=claude

# ───────────────────────────────────────────────────────────────────
# Claude (Anthropic) — по умолчанию
# ───────────────────────────────────────────────────────────────────
# Получить: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5
# Базовый лимит (по умолчанию). Используется, если per-task не задан.
CLAUDE_MAX_TOKENS=8192
# Per-task лимиты токенов (переопределяют CLAUDE_MAX_TOKENS).
# summary  → 7000 символов, помещается в один вызов Claude
# workbook → 14000 символов (v2: 10 секций + кейсы + if-then + трекер)
# tips     → 2500 символов, короткие советы
SUMMARY_MAX_TOKENS=7000
WORKBOOK_MAX_TOKENS=14000
TIPS_MAX_TOKENS=2500

# ───────────────────────────────────────────────────────────────────
# Стиль письма (style injection в system prompt)
# ───────────────────────────────────────────────────────────────────
# Тон:       formal | casual | coaching (по умолчанию coaching — мотивирующе, «ты»)
# Длина:     short | medium | long (кратко / средне / развёрнуто)
# Аудитория: general | expert | teen
# Любая смена стиля автоматически инвалидирует AI-кеш для книги.
WRITING_TONE=coaching
WRITING_LENGTH=medium
WRITING_AUDIENCE=general
WRITING_LANGUAGE=ru

# ───────────────────────────────────────────────────────────────────
# Шаблоны контента (v2+, см. agent/templates/builtin/)
# ───────────────────────────────────────────────────────────────────
# Имена шаблонов ищутся в порядке приоритетов:
#   $TEMPLATES_DIR/{kind}/{name}.md → ./templates/{kind}/{name}.md →
#   agent/templates/builtin/{kind}/{name}.md
# Свой шаблон: создайте templates/summary/my_summary.md с YAML-фронматтером.
TEMPLATE_SUMMARY=summary_v2
TEMPLATE_WORKBOOK=workbook_v2
TEMPLATE_TIPS=tips_v1
# Опц. внешняя папка с шаблонами (если пусто — используется ./templates)
TEMPLATES_DIR=

# ───────────────────────────────────────────────────────────────────
# YandexGPT (Yandex Cloud Foundation Models)
# ───────────────────────────────────────────────────────────────────
# Получить ключ: https://console.yandex.cloud/ → Service accounts → API Key
# Получить folder_id: https://console.yandex.cloud/ → шапка → выбрать каталог → скопировать ID
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# Доступные модели: yandexgpt-lite | yandexgpt | yandexgpt-32k
YANDEX_MODEL=yandexgpt-lite
# Менять URL не нужно, кроме случаев прокси/тестовой среды.
# YANDEX_BASE_URL=https://llm.api.cloud.yandex.net/foundationModels/v1

# ───────────────────────────────────────────────────────────────────
# GigaChat (Сбер)
# ───────────────────────────────────────────────────────────────────
# Получить Authorization Key: https://developers.sber.ru/ → GigaChat API → Ключи
# Это уже base64(client_id:client_secret) — вставляется одной строкой.
GIGACHAT_AUTHORIZATION_KEY=
# Доступные scope: GIGACHAT_API_PERS (физлица) | GIGACHAT_API_CORP (юрлица) | GIGACHAT_API_B2B
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Доступные модели: GigaChat | GigaChat-Pro | GigaChat-Max
GIGACHAT_MODEL=GigaChat
# Отключить проверку SSL (только для корпоративных MITM-сетей). По умолчанию true.
# GIGACHAT_VERIFY_SSL=true

# ───────────────────────────────────────────────────────────────────
# Партнёрские ID магазинов (для buy_links.md)
# ───────────────────────────────────────────────────────────────────
LITRES_PARTNER_ID=123456789
LABIRINT_PARTNER_ID=987654321
OZON_PARTNER_ID=

# ───────────────────────────────────────────────────────────────────
# Пути
# ───────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output/library
CACHE_DIR=./cache
LOGS_DIR=./logs

# ───────────────────────────────────────────────────────────────────
# Поведение
# ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
REQUEST_DELAY=1.0
REQUEST_TIMEOUT=30
MAX_RETRIES=3
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ───────────────────────────────────────────────────────────────────
# Генерация
# ───────────────────────────────────────────────────────────────────
SUMMARY_LANGUAGE=ru
WORKBOOK_LANGUAGE=ru
ENABLE_SCIENTIFIC_SEARCH=true
ENABLE_REVIEWS_SEARCH=true
ENABLE_COVER_DOWNLOAD=true
# Авто-PDF: после генерации summary.md/workbook.md автоматически создаётся
# .pdf (через reportlab, pure-Python, без pandoc).
# Отключить: --no-pdf в CLI или AUTO_PDF=false ниже.
AUTO_PDF=true

# ───────────────────────────────────────────────────────────────────
# Telegram-бот (опционально)
# ───────────────────────────────────────────────────────────────────
# 1. Откройте @BotFather в Telegram, отправьте /newbot, получите токен
# 2. Запустите: python -m agent.telegram_bot
TELEGRAM_BOT_TOKEN=
# Ваш Telegram user_id (int). 0 = бот отвечает всем.
# Узнать: напишите @userinfobot
TELEGRAM_ADMIN_ID=0
# SOCKS5/HTTP прокси (если api.telegram.org недоступен напрямую).
# Примеры:
#   socks5://user:pass@127.0.0.1:1080
#   http://proxy.corp:8080
#   127.0.0.1:1080           ← автоматически трактуется как socks5
# Пусто = без прокси.
TELEGRAM_PROXY_URL=

# ───────────────────────────────────────────────────────────────────
# ВКонтакте-бот (опционально)
# ───────────────────────────────────────────────────────────────────
# 1. https://vk.com/groups → Создать сообщество
# 2. Настройки сообщества → Работа с API → Ключи доступа → Создать ключ
# 3. Включите Long Poll API (Настройки → Работа с API → Long Poll API)
# 4. Включите Сообщения сообщества (Настройки → Сообщения)
# 5. Скопируйте токен (vk1.a....) и числовой ID сообщества
# 6. Запустите: python -m agent.vk_bot
VK_GROUP_TOKEN=
VK_GROUP_ID=0
# Прокси для VK (обычно НЕ нужен — api.vk.com доступен из РФ):
VK_PROXY_URL=
# Отключить проверку TLS-сертификата VK (корпоративный MITM).
# По умолчанию проверка включена. Допустимые значения: true | false.
VK_VERIFY_SSL=true

# ───────────────────────────────────────────────────────────────────
# Источник книг
# ───────────────────────────────────────────────────────────────────
# Основной сайт: https://www.koob.ru/{author}/{book} — полные тексты, отзывы
# Зеркало:      https://oko.koob.ru/{book}/        — legacy
# Парсер автоматически определяет, какое зеркало использовать.
KOOB_BASE_URL=https://www.koob.ru
KOOB_ALTERNATE_MIRROR=https://oko.koob.ru
