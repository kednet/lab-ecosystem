---
/**
 * VideoReviews.astro — рендер видео-отзывов внутри таба "Отзывы".
 * Источник: src/data/books/<slug>/video_reviews.json (или fallback через source_path / author)
 */
import { loadVideoReviews } from '../lib/video_reviews';
import type { VideoReview } from '../lib/video_reviews';

interface Props {
  slug: string;
  bookTitle: string;
  bookAuthor: string;
}

const { slug, bookTitle, bookAuthor } = Astro.props;
const bundle = loadVideoReviews(slug);

if (!bundle || bundle.videos.length === 0) {
  // Ничего не рендерим — пустая секция
}

// === Helpers ===
const isAuthorScope = bundle?.scope === 'author';
const scopeLabel = isAuthorScope ? 'об авторе' : 'о книге';
const recommendationMap: Record<string, { label: string; tone: 'good' | 'mid' | 'bad' | 'none' }> = {
  'рекомендует': { label: 'Рекомендует', tone: 'good' },
  'с оговорками': { label: 'С оговорками', tone: 'mid' },
  'не рекомендует': { label: 'Не рекомендует', tone: 'bad' },
  'без оценки': { label: 'Без оценки', tone: 'none' },
};
const sentimentMap: Record<string, { label: string; tone: 'good' | 'mid' | 'bad' | 'none' }> = {
  positive: { label: 'Положительный', tone: 'good' },
  mixed: { label: 'Смешанный', tone: 'mid' },
  negative: { label: 'Отрицательный', tone: 'bad' },
  neutral: { label: 'Нейтральный', tone: 'none' },
};

function formatViews(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)} млн`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(1)}К`;
  return String(n);
}

function formatDate(iso: string): string {
  if (!iso) return '';
  try {
    const d = new Date(iso);
    return d.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long' });
  } catch {
    return iso.slice(0, 7);
  }
}
---

{bundle && bundle.videos.length > 0 && (
  <div class="video-reviews" data-video-reviews>
    {isAuthorScope && (
      <div class="video-reviews__notice">
        📚 Видео {scopeLabel} <strong>{bundle.author}</strong>, а не о книге «{bookTitle}».
      </div>
    )}

    <div class="video-reviews__grid">
      {bundle.videos.map((v: VideoReview) => {
        const rec = v.recommendation ? recommendationMap[v.recommendation] : null;
        const sent = v.sentiment ? sentimentMap[v.sentiment] : null;
        const firstQuote = v.key_quotes?.[0];

        return (
          <article class="video-card">
            <a
              class="video-card__thumb"
              href={v.watch_url}
              target="_blank"
              rel="noopener"
              aria-label={`Смотреть на YouTube: ${v.title}`}
              data-vid={v.video_id}
              data-vchannel={v.channel}
              data-vscope={bundle.scope}
              data-vplace="thumb"
              data-book-slug={slug}
            >
              <img
                src={v.thumbnail_default}
                alt={`Превью видео: ${v.title}`}
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <span class="video-card__duration">{v.duration_str}</span>
              <span class="video-card__play" aria-hidden="true">▶</span>
            </a>

            <div class="video-card__body">
              <h4 class="video-card__title">
                <a
                  href={v.watch_url}
                  target="_blank"
                  rel="noopener"
                  data-vid={v.video_id}
                  data-vchannel={v.channel}
                  data-vscope={bundle.scope}
                  data-vplace="title"
                  data-book-slug={slug}
                >{v.title}</a>
              </h4>

              <div class="video-card__meta">
                <span class="video-card__channel">{v.channel}</span>
                <span class="video-card__sep">·</span>
                <span class="video-card__views">{formatViews(v.views)} просм.</span>
                <span class="video-card__sep">·</span>
                <time class="video-card__date" datetime={v.published_at}>{formatDate(v.published_at)}</time>
              </div>

              {v.summary && (
                <p class="video-card__summary">{v.summary}</p>
              )}

              {firstQuote && (
                <blockquote class="video-card__quote">
                  «{firstQuote.text}»
                  <cite>
                    — таймкод <a
                      href={`${v.watch_url}&t=${firstQuote.timestamp}`}
                      target="_blank"
                      rel="noopener"
                      data-vid={v.video_id}
                      data-vchannel={v.channel}
                      data-vscope={bundle.scope}
                      data-vplace="quote_ts"
                      data-book-slug={slug}
                    >{firstQuote.timestamp}</a>
                  </cite>
                </blockquote>
              )}

              <div class="video-card__tags">
                {rec && <span class={`video-card__tag video-card__tag--${rec.tone}`}>{rec.label}</span>}
                {sent && <span class={`video-card__tag video-card__tag--${sent.tone}`}>{sent.label}</span>}
                {v.topics?.slice(0, 3).map((t) => (
                  <span class="video-card__tag video-card__tag--topic">{t}</span>
                ))}
              </div>

              <a
                class="video-card__cta"
                href={v.watch_url}
                target="_blank"
                rel="noopener"
                data-vid={v.video_id}
                data-vchannel={v.channel}
                data-vscope={bundle.scope}
                data-vplace="cta"
                data-book-slug={slug}
              >
                Смотреть на YouTube →
              </a>
            </div>
          </article>
        );
      })}
    </div>

    <p class="video-reviews__footer">
      Источник: YouTube. Это не наши видео — мы собираем чужие обзоры, чтобы вы могли услышать разные мнения.
      <br />
      <a href="https://www.youtube.com/" target="_blank" rel="noopener">Открыть YouTube</a>
    </p>
  </div>
)}

<script is:inline>
  // Метрика: фиксируем клик по любой ссылке внутри видео-карточки.
  // Делегируем на корень секции — на одной карточке 4 ссылки, не плодим слушатели.
  (function () {
    if (window.__videoReviewsMetrikaInited) return;
    window.__videoReviewsMetrikaInited = true;

    function onClick(e) {
      var link = e.target && e.target.closest && e.target.closest('a[data-vid]');
      if (!link) return;
      // Пропускаем "Открыть YouTube" в футере — у него нет data-vid
      window.labReachGoal('video_review_clicked', {
        slug: link.getAttribute('data-book-slug') || '',
        video_id: link.getAttribute('data-vid') || '',
        channel: link.getAttribute('data-vchannel') || '',
        scope: link.getAttribute('data-vscope') || '',
        place: link.getAttribute('data-vplace') || '',
      });
    }

    // capture:true — открытие ссылки в новой вкладке уничтожает текущий контекст,
    // bubble-фаза может не успеть отправить хит.
    document.addEventListener('click', onClick, true);
  })();
</script>

<style>
  .video-reviews { margin-top: 24px; }

  .video-reviews__notice {
    background: #fef3c7;
    border-left: 3px solid #f59e0b;
    padding: 12px 16px;
    border-radius: 6px;
    font-size: 14px;
    color: #78350f;
    margin-bottom: 20px;
  }

  .video-reviews__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 16px;
  }

  @media (min-width: 720px) {
    .video-reviews__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .video-reviews__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .video-card {
    border: 1px solid var(--line, #e5e7eb);
    border-radius: 12px;
    overflow: hidden;
    background: var(--surface, #fff);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .video-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .video-card__thumb {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #000;
  }

  .video-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-card__duration {
    position: absolute;
    right: 8px;
    bottom: 8px;
    background: rgba(0, 0, 0, 0.85);
    color: #fff;
    font-size: 12px;
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 500;
  }

  .video-card__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(0, 0, 0, 0.15);
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }

  .video-card:hover .video-card__play { opacity: 1; }

  .video-card__body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 8px;
  }

  .video-card__title {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
  }

  .video-card__title a {
    color: var(--text, #1a1a1a);
    text-decoration: none;
  }

  .video-card__title a:hover {
    color: var(--rose, #e11d48);
  }

  .video-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 12px;
    color: var(--text-soft, #6b7280);
  }

  .video-card__sep { color: #d1d5db; }

  .video-card__summary {
    margin: 4px 0 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text, #1a1a1a);
  }

  .video-card__quote {
    margin: 4px 0 0;
    padding: 10px 12px;
    background: #f9fafb;
    border-left: 3px solid var(--rose, #e11d48);
    font-size: 13px;
    font-style: italic;
    line-height: 1.4;
    color: var(--text-soft, #4b5563);
    border-radius: 0 4px 4px 0;
  }

  .video-card__quote cite {
    display: block;
    margin-top: 4px;
    font-size: 11px;
    font-style: normal;
    color: var(--text-soft, #6b7280);
  }

  .video-card__quote cite a {
    color: var(--rose, #e11d48);
    text-decoration: none;
    font-weight: 500;
  }

  .video-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 4px;
  }

  .video-card__tag {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 12px;
    background: #f3f4f6;
    color: #4b5563;
  }

  .video-card__tag--good { background: #d1fae5; color: #065f46; }
  .video-card__tag--mid  { background: #fef3c7; color: #78350f; }
  .video-card__tag--bad  { background: #fee2e2; color: #991b1b; }
  .video-card__tag--none { background: #f3f4f6; color: #6b7280; }
  .video-card__tag--topic { background: #f3e8ff; color: #6b21a8; }

  .video-card__cta {
    display: inline-block;
    margin-top: auto;
    padding-top: 8px;
    font-size: 13px;
    font-weight: 500;
    color: var(--rose, #e11d48);
    text-decoration: none;
  }

  .video-card__cta:hover {
    text-decoration: underline;
  }

  .video-reviews__footer {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--line, #e5e7eb);
    font-size: 12px;
    color: var(--text-soft, #6b7280);
    line-height: 1.5;
  }

  .video-reviews__footer a {
    color: var(--rose, #e11d48);
    text-decoration: none;
  }
</style>