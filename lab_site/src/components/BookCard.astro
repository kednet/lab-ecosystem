---
interface Props {
  slug: string;
  title: string;
  author: string;
  year?: number | string;
  description?: string;
  cover?: string | null;
  tags?: string[];
}
const { slug, title, author, year, description, cover, tags = [] } = Astro.props;
const initial = title.trim().charAt(0).toUpperCase();
---
<a class="book-card" href={`/library/${slug}/`}>
  <div class="book-card__cover">
    {cover
      ? <img src={cover} alt={`Обложка: ${title}`} loading="lazy" />
      : <div class="book-card__cover-fallback">{initial}</div>
    }
  </div>
  <div class="book-card__body">
    <h3 class="book-card__title">{title}</h3>
    <div class="book-card__author">
      {author}{year ? ` · ${year}` : ''}
    </div>
    {description && <p class="book-card__desc">{description}</p>}
    {tags.length > 0 && (
      <div class="book-card__tags">
        {tags.slice(0, 3).map((t) => <span class="book-card__tag">{t}</span>)}
      </div>
    )}
    <span class="book-card__link">Открыть конспект →</span>
  </div>
</a>
