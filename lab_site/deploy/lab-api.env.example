# lab-api.env.example
#
# Копируется на VPS как /home/deploy/app/worker/.env
# ВАЖНО: 600 (только deploy:deploy читает)
#
#   sudo cp deploy/lab-api.env.example /home/deploy/app/worker/.env
#   sudo chown deploy:deploy /home/deploy/app/worker/.env
#   sudo chmod 600 /home/deploy/app/worker/.env
#   nano /home/deploy/app/worker/.env   # отредактировать JWT_SECRET и секреты
#
# Потом:
#   sudo systemctl enable --now lab-api
#   sudo journalctl -u lab-api -f

# ── Окружение ──
ENVIRONMENT=production
FRONTEND_ORIGIN=https://app.pulab.online

# ── JWT-секрет (сгенерировать: openssl rand -hex 32) ──
JWT_SECRET=REPLACE_ME_with_64_hex_chars_from_openssl_rand_hex_32
# Fallback для dev (НЕ ИСПОЛЬЗУЕТСЯ в production, если задан JWT_SECRET)
JWT_SECRET_DEV=dev-only-fallback

# ── SQLite для замены Cloudflare KV ──
SQLITE_PATH=/var/lib/lab-site/kv.db

# ── Email (Resend) ──
RESEND_API_KEY=re_REPLACE_ME

# ── Python-сервис (WishLibrarian) — оставлен на Render.com ──
PYTHON_SERVICE_URL=https://lab-site-python.onrender.com
PYTHON_SERVICE_TOKEN=REPLACE_ME_shared_secret

# ── ЮKassa (платежи) ──
YOOKASSA_SHOP_ID=REPLACE_ME
YOOKASSA_SECRET_KEY=REPLACE_ME
YOOKASSA_WEBHOOK_SECRET=REPLACE_ME

# ── VK Publisher (анонсы в группу pulabru 237295798) ──
VK_GROUP_TOKEN=REPLACE_ME_vk_token
VK_GROUP_ID=237295798

# ── Telegram Publisher (анонсы + callback) ──
TELEGRAM_BOT_TOKEN=REPLACE_ME_tg_token
TELEGRAM_ADMIN_ID=REPLACE_ME_numeric_chat_id
TELEGRAM_CHANNEL_ID=@wishlab_channel

# ── HTTP-сервер ──
PORT=8787
HOST=127.0.0.1
