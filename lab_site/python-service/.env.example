# Конфигурация python-service.
# Копируется в .env на Render.

# Callback к Worker-у: каждый stage пишем сюда
WORKER_CALLBACK_URL=https://lab-site-api.example.workers.dev
# Общий секрет для авторизации callback (тот же, что в Worker PYTHON_SERVICE_TOKEN)
PYTHON_SERVICE_TOKEN=change-me-long-random-string

# Папка для обработанных книг (тот же, что читает Astro)
WL_OUTPUT_DIR=/tmp/wl-output

# Сколько polling-тасков держать одновременно
MAX_CONCURRENT_JOBS=2

# Как часто опрашивать KV на новые pending jobs (сек)
POLL_INTERVAL_SEC=2

# Корпоративный MITM — не используется на Render, оставлено для локали
# PYTHONHTTPSVERIFY=0
