# Chief Agent v2.0 — environment variables
# Copy to .env on VPS, fill values, chmod 600.

# === HTTP server ===
CHIEF_PORT=7070
CHIEF_BIND=127.0.0.1
CHIEF_WS_PATH=/ws

# === Auth ===
# Generate with: openssl rand -hex 32
# UI token (Bearer, для /api/* кроме /api/health и /api/tg/webhook)
CHIEF_API_TOKEN=replace-me-with-32-byte-hex-from-openssl
# Admin token (X-Admin-Token, для POST/PUT/DELETE /api/agents и /api/system/restart)
CHIEF_ADMIN_TOKEN=replace-me-with-another-32-byte-hex-from-openssl
# Kednet-агент WS auth (шлёт в hello-сообщении по WS)
KEDNET_AGENT_TOKEN=replace-me-with-third-32-byte-hex-from-openssl

# === Telegram ===
# Bot @ChiefAgentbot (создайте через @BotFather, положите токен сюда)
TG_BOT_TOKEN=
# Chat id (kfigh personal) — числовой id или @username
TG_CHAT_ID=
# Webhook secret (setWebhook?secret_token=...)
TG_WEBHOOK_SECRET=
# Bot name (для логов и audit)
TG_BOT_NAME=@ChiefAgentbot
# Approval timeout (auto-reject after N seconds, default 24h)
CHIEF_APPROVAL_TIMEOUT=86400
# Re-ping reminder interval (default 1h)
CHIEF_APPROVAL_REMINDER=3600

# === Upstream HTTP agents ===
COACH_API_URL=https://coach-agent.onrender.com
LAB_SITE_API_URL=https://api.pulab.online

# === Behavior ===
CHIEF_HEARTBEAT_INTERVAL=30
CHIEF_STDOUT_CAP_BYTES=5242880
CHIEF_INSECURE_TLS=0