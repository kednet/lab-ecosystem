# YandexGPT API ключ
# Получить: https://console.yandex.cloud/ → Service accounts → API Key
# Получить folder_id: https://console.yandex.cloud/ → шапка → выбрать каталог → скопировать ID

YANDEX_API_KEY=AQVNxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
YANDEX_FOLDER_ID=b1xxxxxxxxxxxxxxxxxxxxx

# Доступные модели:
# - yandexgpt-lite (дешёвая, 8k контекст) — для генерации желаний
# - yandexgpt (средняя, 8k контекст)
# - yandexgpt-32k (большая, 32k контекст)
YANDEX_MODEL=yandexgpt-lite

# Корпоративный MITM — обязательно false
YANDEX_VERIFY_SSL=false

# GigaChat (опциональный fallback)
GIGACHAT_AUTHORIZATION_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_VERIFY_SSL=false
