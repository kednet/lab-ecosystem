# AdvCake → Литрес affiliate integration
# Скопируй в .env и подставь реальные значения.

# Уникальный ID твоей ссылки в ЛК AdvCake (видно в "Мои источники" или в URL)
ADVCAKE_HASH=c280b701

# Маркер рекламы из ОРД (ЕРИР), действующий erid
ADVCAKE_ERID=2VfnxyNkZrY

# Домен Литреса (https, без завершающего /)
ADVCAKE_BASE_URL=https://www.litres.ru

# Имя кампании в UTM (utm_campaign)
ADVCAKE_CAMPAIGN=affiliate

# Метод атрибуции (1 = postback)
ADVCAKE_METHOD=1

# Опционально: Bearer-токен ОРД VK для проверки статуса erid через API.
# Получить: https://ord.vk.com → Настройки → API-ключи.
# Если не задан, verify_erid() работает в режиме best-effort.
ORD_BEARER_TOKEN=