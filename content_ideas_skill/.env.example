# ╔══════════════════════════════════════════════════════════════════╗
# ║  content-ideas-skill — пример .env (скопируй в .env и заполни)   ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# По умолчанию скрипт ищет токены в:
#   1. Сам .env (этот файл → переименуй в .env без .example)
#   2. C:\Users\kfigh\publisher_skill\.env
#   3. C:\Users\kfigh\wish_librarian\.env
#   4. Другие .env (см. ENV_FALLBACKS в fetch_vk_posts.py)
#
# Если токены уже есть в другом скиле — свой .env не обязателен.

# ───────────────────────────────────────────────────────────────────
# VK API (для fetch_vk_posts.py, fetch_comments.py)
# ───────────────────────────────────────────────────────────────────
# Токен VK_ACCESS_TOKEN читается из publisher_skill/.env по умолчанию.
# Если хочешь переопределить — раскомментируй:
# VK_ACCESS_TOKEN=vk1.a.xxxxx

# Отключить проверку TLS (корпоративный MITM)
# VK_VERIFY_SSL=false

# ───────────────────────────────────────────────────────────────────
# LLM (для generate_ideas.py, mine_audience_pains.py, extract_themes.py)
# ───────────────────────────────────────────────────────────────────
# Провайдер: claude | yandex | gigachat
# LLM_PROVIDER=claude

# Claude (Anthropic)
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# CLAUDE_MODEL=claude-sonnet-4-5

# YandexGPT
# YANDEX_API_KEY=AQVNxxxxx
# YANDEX_FOLDER_ID=b1xxxxx
# YANDEX_MODEL=yandexgpt

# GigaChat
# GIGACHAT_AUTHORIZATION_KEY=xxxxx
# GIGACHAT_SCOPE=GIGACHAT_API_PERS
# GIGACHAT_MODEL=GigaChat
# GIGACHAT_VERIFY_SSL=false

# ───────────────────────────────────────────────────────────────────
# Прокси (если нужен)
# ───────────────────────────────────────────────────────────────────
# HTTP_PROXY=http://proxy.corp:8080
# HTTPS_PROXY=http://proxy.corp:8080
