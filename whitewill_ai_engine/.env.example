# ============================================
# Yandex Cloud / YandexGPT
# ============================================
# Folder ID (идентификатор каталога в Yandex Cloud)
YANDEX_FOLDER_ID=b1gXXXXXXXXXXXXXXXX
# API-ключ сервисного аккаунта (Editor или ai.languageModels.user)
YANDEX_API_KEY=AQVNxxxxxxxxxxxxxxxxx
# IAM-токен для SpeechKit и Translate (можно использовать тот же API-ключ)
YANDEX_IAM_TOKEN=

# ============================================
# Модели
# ============================================
YANDEX_GPT_MODEL=yandexgpt
YANDEX_GPT_VERSION=rc
YANDEX_EMBEDDINGS_MODEL=text-search-doc
# Стоимость (₽ за 1k токенов) — для расчёта в логах
YANDEX_GPT_INPUT_PRICE=0.5
YANDEX_GPT_OUTPUT_PRICE=2.0

# ============================================
# SpeechKit (голосовые сообщения)
# ============================================
SPEECHKIT_ENABLED=false
SPEECHKIT_LANG=ru-RU
SPEECHKIT_VOICE=alena

# ============================================
# Telegram
# ============================================
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_BROKER_CHAT_ID=-1001234567890  # чат/группа для брокеров
TELEGRAM_ADMIN_CHAT_ID=123456789  # личка админа для алертов

# ============================================
# Bitrix24 (mock для demo)
# ============================================
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/xxxxxxxxxxxxx/
BITRIX24_MOCK_MODE=true  # для demo не делаем реальных вызовов

# ============================================
# Off-market источники (mock для demo)
# ============================================
EGRN_API_MODE=mock  # real | mock
EGRN_API_KEY=
FSSP_API_MODE=mock
FSSP_API_KEY=

# ============================================
# Storage
# ============================================
DATABASE_URL=sqlite+aiosqlite:///./data/whitewill.db
REDIS_URL=redis://localhost:6379/0  # опционально для кеша

# ============================================
# Логирование
# ============================================
LOG_LEVEL=INFO
ENV=development
